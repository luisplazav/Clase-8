            <h2>PROYECTOS DE TГҚTULO</h2>

            <input type="text" id="elInput" placeholder="Filtrar tГӯtulosвҖҰ" />
            <div id="contenedordetabla">
                <table>
                    <thead>
                        <tr>
                            <th>Autor</th>
                            <th>Proyecto</th>
                            <th>Nota</th>
                            <th>Category</th>
<th>Prof. guГӯa</th>
                        </tr>
                    </thead>
                    <tbody id="este"></tbody>
                </table>
            </div>
 















<small>DiseГұo y visualizaciГіn de informaciГіn</small>
        </div>

        <script>
            const t = document.querySelector("#este");
            const URL = "https://api.myjson.online/v1/records/ff7d321d-9b3a-47f2-9a14-52b3e8543d5e";

            fetch(URL)
                .then((respuesta) => {
                    if (!respuesta.ok) {
                        throw new Error("Error HTTP: " + respuesta.status);
                    }
                    return respuesta.json();
                })
                .then((datos) => {
                    var trabajo = datos.data;
                    console.log(trabajo);
                    trabajo.forEach((x) => {
                        t.innerHTML += `<tr style="${x.ok == 1 ? "background-color: var(--color-iluminadisimo); color: var(--color-oscurisimo)" : ""}"><td>${x.name}</td><td>${x.title}</td><td>${x.grade}</td><td>${x.category}</td><td>${x.tutor}</td></tr>`;
                    });
                })
                .catch((error) => {
                    console.error("Algo saliГі mal:", error);
                });

            function sinAcentos(str) {
                return str.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            }

            document.getElementById("elInput").addEventListener("keyup", function () {
                const valor = sinAcentos(this.value.toLowerCase());
                document.querySelectorAll("#este tr").forEach(function (fila) {
                    fila.style.display = sinAcentos(fila.textContent.toLowerCase()).includes(valor) ? "" : "none";
                });
            });
        </script>
